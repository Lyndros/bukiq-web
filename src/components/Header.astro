---
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm transition-shadow duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex-shrink-0">
        <img src="/bukiq-logo.svg" alt="Bukiq" class="h-9 lg:h-10 w-auto" />
      </a>

      <nav class="hidden lg:flex items-center gap-8">
        <a
          href="#funcionalidades"
          class="text-sm font-medium text-gray-600 hover:text-azul transition-colors"
          >Funcionalidades</a
        >
        <a
          href="#como-funciona"
          class="text-sm font-medium text-gray-600 hover:text-azul transition-colors"
          >Cómo funciona</a
        >
        <a
          href="#beneficios"
          class="text-sm font-medium text-gray-600 hover:text-azul transition-colors"
          >Beneficios</a
        >
        <a
          href="#faq"
          class="text-sm font-medium text-gray-600 hover:text-azul transition-colors"
          >Preguntas frecuentes</a
        >
      </nav>

      <div class="hidden lg:flex items-center gap-3">
        <a
          href="#como-funciona"
          class="text-sm font-medium text-azul hover:text-azul/80 transition-colors"
        >
          Ver cómo funciona
        </a>
        <a
          href="https://cal.eu/bukiq/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-5 py-2.5 bg-azul text-white text-sm font-semibold rounded-lg hover:bg-azul/90 transition-colors"
        >
          Solicitar demo
        </a>
      </div>

      <button
        id="menu-toggle"
        class="lg:hidden p-2 text-gray-600 hover:text-azul transition-colors"
        aria-label="Abrir menú de navegación"
      >
        <svg
          id="menu-icon"
          class="w-6 h-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="w-6 h-6 hidden"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden lg:hidden border-t border-gray-100 bg-white"
  >
    <div class="px-4 py-4 space-y-3">
      <a
        href="#funcionalidades"
        class="block text-sm font-medium text-gray-600 hover:text-azul transition-colors"
        >Funcionalidades</a
      >
      <a
        href="#como-funciona"
        class="block text-sm font-medium text-gray-600 hover:text-azul transition-colors"
        >Cómo funciona</a
      >
      <a
        href="#beneficios"
        class="block text-sm font-medium text-gray-600 hover:text-azul transition-colors"
        >Beneficios</a
      >
      <a
        href="#faq"
        class="block text-sm font-medium text-gray-600 hover:text-azul transition-colors"
        >Preguntas frecuentes</a
      >
      <div class="pt-3 border-t border-gray-100 space-y-2">
        <a href="#como-funciona" class="block text-sm font-medium text-azul"
          >Ver cómo funciona</a
        >
        <a
          href="https://cal.eu/bukiq/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full text-center px-5 py-2.5 bg-azul text-white text-sm font-semibold rounded-lg hover:bg-azul/90 transition-colors"
        >
          Solicitar demo
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('header');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('shadow-md', window.scrollY > 10);
  });

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
