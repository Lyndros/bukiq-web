---
---

<section class="relative pt-28 lg:pt-36 pb-20 lg:pb-28 bg-gradient-to-b from-white to-gray-50 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Texto -->
      <div class="max-w-xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-verde/10 text-verde text-sm font-semibold rounded-full mb-6">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Disponible 24 horas, 7 días
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-extrabold text-azul leading-tight tracking-tight">
          Tus reservas, atendidas 24/7 aunque nadie coja el teléfono
        </h1>

        <p class="mt-6 text-lg text-gray-600 leading-relaxed">
          Bukiq es el asistente de voz que atiende las llamadas de reserva de tu restaurante a cualquier hora. Mientras tu equipo está en sala, Bukiq gestiona las solicitudes y mantiene tus reservas bajo control.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="https://cal.eu/bukiq/30min"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3.5 bg-azul text-white font-semibold rounded-lg hover:bg-azul/90 transition-colors text-base"
          >
            Solicitar demo
            <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a
            href="#como-funciona"
            class="inline-flex items-center justify-center px-6 py-3.5 border-2 border-azul/20 text-azul font-semibold rounded-lg hover:border-azul/40 hover:bg-azul/5 transition-colors text-base"
          >
            Ver cómo funciona
          </a>
        </div>

        <p class="mt-8 text-sm text-gray-500 flex items-center gap-2">
          <svg class="w-4 h-4 text-verde flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          Diseñado para restaurantes que no quieren perder ni una reserva
        </p>
      </div>

      <!-- Mockup del dashboard -->
      <div class="relative lg:ml-4">
        <div class="absolute -inset-4 bg-azul/5 rounded-3xl -rotate-2"></div>
        <div class="relative bg-white rounded-2xl shadow-2xl border border-gray-200 overflow-hidden">
          <!-- Barra del navegador -->
          <div class="bg-gray-800 px-4 py-2.5 flex items-center gap-2">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-400"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
              <div class="w-3 h-3 rounded-full bg-green-400"></div>
            </div>
            <div class="flex-1 mx-8">
              <div class="bg-gray-700 rounded-md px-3 py-1 text-xs text-gray-400 text-center">
                app.bukiq.es
              </div>
            </div>
          </div>

          <!-- Barra superior del panel -->
          <div class="bg-azul px-4 py-2.5 flex items-center gap-3">
            <span class="text-white font-bold text-sm">Bukiq</span>
            <span class="text-white/60 text-xs">Panel de reservas</span>
            <div class="ml-auto w-6 h-6 rounded-full bg-white/20"></div>
          </div>

          <!-- Contenido -->
          <div class="p-4 space-y-4">
            <!-- Estadísticas -->
            <div class="grid grid-cols-3 gap-3">
              <div class="bg-azul/5 rounded-lg p-3 text-center">
                <div class="text-xl font-bold text-azul">12</div>
                <div class="text-[11px] text-gray-500">Reservas hoy</div>
              </div>
              <div class="bg-verde/10 rounded-lg p-3 text-center">
                <div class="text-xl font-bold text-verde">3</div>
                <div class="text-[11px] text-gray-500">Nuevas solicitudes</div>
              </div>
              <div class="bg-azul/5 rounded-lg p-3 text-center">
                <div class="text-xl font-bold text-azul">48</div>
                <div class="text-[11px] text-gray-500">Esta semana</div>
              </div>
            </div>

            <!-- Lista de reservas -->
            <div>
              <div class="text-[11px] font-semibold text-gray-400 uppercase tracking-wide mb-2">
                Próximas reservas
              </div>
              <div class="space-y-2">
                <div class="flex items-center gap-3 bg-gray-50 rounded-lg p-2.5">
                  <div class="w-8 h-8 rounded-full bg-azul/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-azul" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium text-gray-900">García López · 4 pax</div>
                    <div class="text-xs text-gray-500">20:30 h</div>
                  </div>
                  <span class="inline-flex px-2 py-0.5 rounded-full text-[11px] font-medium bg-verde/10 text-verde">
                    Confirmada
                  </span>
                </div>
                <div class="flex items-center gap-3 bg-gray-50 rounded-lg p-2.5">
                  <div class="w-8 h-8 rounded-full bg-azul/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-azul" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium text-gray-900">Martínez R. · 2 pax</div>
                    <div class="text-xs text-gray-500">21:00 h</div>
                  </div>
                  <span class="inline-flex px-2 py-0.5 rounded-full text-[11px] font-medium bg-yellow-100 text-yellow-700">
                    Pendiente
                  </span>
                </div>
                <div class="flex items-center gap-3 bg-gray-50 rounded-lg p-2.5">
                  <div class="w-8 h-8 rounded-full bg-azul/10 flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4 text-azul" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium text-gray-900">Fernández P. · 6 pax</div>
                    <div class="text-xs text-gray-500">21:30 h</div>
                  </div>
                  <span class="inline-flex px-2 py-0.5 rounded-full text-[11px] font-medium bg-verde/10 text-verde">
                    Confirmada
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
