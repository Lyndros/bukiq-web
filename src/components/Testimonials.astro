---
const testimonials = [
  {
    name: 'Marta G.',
    role: 'Gerente',
    business: 'Restaurante La Terraza',
    quote: 'Desde que usamos Bukiq, hemos dejado de perder reservas en las horas de más trabajo. El asistente de voz atiende las llamadas mientras nosotros estamos en sala, y todo queda registrado en el panel. Es una tranquilidad enorme.',
    initials: 'MG',
    image: '/images/avatar-marta.jpg',
  },
  {
    name: 'Carlos V.',
    role: 'Propietario',
    business: 'Asador El Rincón',
    quote: 'Antes perdíamos llamadas constantemente, sobre todo a mediodía. Ahora el asistente las gestiona y nosotros solo tenemos que confirmar desde el panel. Ha sido un cambio enorme en nuestra organización diaria.',
    initials: 'CV',
    image: '/images/avatar-carlos.jpg',
  },
  {
    name: 'Laura P.',
    role: 'Responsable de sala',
    business: 'Bistró Azahar',
    quote: 'Lo que más valoro es la tranquilidad de saber que ninguna llamada se queda sin respuesta. Puedo revisar todas las solicitudes cuando tengo un momento y el panel es muy fácil de usar. Se lo recomiendo a cualquier restaurante.',
    initials: 'LP',
    image: '/images/avatar-laura.jpg',
  },
];
---

<section class="py-20 lg:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-azul">
        Lo que dicen quienes ya lo usan
      </h2>
      <p class="mt-4 text-lg text-gray-600 max-w-2xl mx-auto">
        Restaurantes que han mejorado la gestión de sus reservas con Bukiq.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {testimonials.map((testimonial) => (
        <div class="bg-white rounded-2xl p-6 lg:p-8 border border-gray-100 shadow-sm">
          <!-- Estrellas -->
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Cita -->
          <blockquote class="text-gray-600 text-sm leading-relaxed mb-6">
            "{testimonial.quote}"
          </blockquote>

          <!-- Autor -->
          <div class="flex items-center gap-3">
            <img
              src={testimonial.image}
              alt={`Foto de ${testimonial.name}`}
              class="w-10 h-10 rounded-full object-cover bg-azul/10"
              onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
            />
            <div
              class="w-10 h-10 rounded-full bg-azul/10 items-center justify-center text-azul text-sm font-bold hidden"
            >
              {testimonial.initials}
            </div>
            <div>
              <div class="text-sm font-semibold text-gray-900">{testimonial.name}</div>
              <div class="text-xs text-gray-500">{testimonial.role} · {testimonial.business}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
